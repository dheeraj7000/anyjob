# --- LLM provider ---
# LLM_TRANSPORT selects how chatStructured() talks to a model:
#   openai (default): any OpenAI-compatible /chat/completions endpoint
#   anyapi-daemon: route through a locally running anyapi daemon instead
#     (e.g. DeepSeek's free web chat, automated via Playwright by the
#     anyapi project at /root/myai/anyapi). No API key needed, but you
#     must start the daemon yourself first: anyapi-daemon --provider deepseek
LLM_TRANSPORT=openai

# --- openai transport settings (ignored when LLM_TRANSPORT=anyapi-daemon) ---
# Examples:
#   OpenAI:      https://api.openai.com/v1
#   Cerebras:    https://api.cerebras.ai/v1
#   NVIDIA NIM:  https://integrate.api.nvidia.com/v1
#   Local Ollama:http://localhost:11434/v1
#   vLLM:        http://localhost:8000/v1
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# --- anyapi-daemon transport settings (ignored when LLM_TRANSPORT=openai) ---
ANYAPI_PROVIDER=deepseek
# ANYAPI_SOCKET_PATH=/root/.local/share/anyapi/deepseek_daemon.sock  # optional override
# ANYAPI_BRIDGE_SCRIPT=./scripts/anyapi_bridge.py                     # optional override
# ANYAPI_PYTHON_BIN=python3                                           # optional override

# --- Candidate identity (never commit real values) ---
CANDIDATE_RESUME_PATH=./data/resume.pdf

# --- Per-site credentials (add one block per site you automate) ---
# Never paste session cookies here. These are your normal login credentials,
# used only locally by Playwright to drive a real login flow.
WORKDAY_ASU_URL=https://www.myworkday.com/asu
WORKDAY_ASU_USERNAME=
WORKDAY_ASU_PASSWORD=

# Playwright stores logged-in session state here after a successful login,
# so you don't have to re-enter credentials on every run.
STORAGE_STATE_DIR=./data/storage-state
